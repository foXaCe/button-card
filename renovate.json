{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    "group:allNonMajor",
    ":dependencyDashboard",
    ":enableVulnerabilityAlertsWithLabel('security')",
    ":maintainLockFilesWeekly",
    ":timezone(Europe/Paris)",
    "schedule:nonOfficeHours"
  ],
  "baseBranchPatterns": ["main"],
  "labels": ["dependencies"],
  "assignees": ["foXaCe"],
  "prCreation": "immediate",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "rangeStrategy": "bump",
  "rebaseWhen": "auto",
  "minimumReleaseAge": "3 days",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "📦 Renovate Dependency Dashboard",
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "schedule": ["at any time"],
    "prCreation": "immediate",
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Auto-merge safe updates",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true,
      "labels": ["dependencies", "auto-merge"]
    },
    {
      "description": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github-actions"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "npm deps",
      "matchManagers": ["npm"],
      "labels": ["dependencies", "javascript"]
    },
    {
      "description": "Lit",
      "groupName": "lit",
      "matchPackageNames": ["lit", "lit-element", "lit-html", "/^@lit//"]
    },
    {
      "description": "Rollup toolchain",
      "groupName": "rollup",
      "matchPackageNames": ["rollup", "/^@rollup//", "/^rollup-plugin-/"]
    },
    {
      "description": "Lint & format",
      "groupName": "eslint & prettier",
      "matchPackageNames": ["/eslint/", "/prettier/"]
    },
    {
      "description": "semantic-release",
      "groupName": "semantic-release",
      "matchPackageNames": ["semantic-release", "/^@semantic-release//"]
    },
    {
      "description": "Babel",
      "groupName": "babel",
      "matchPackageNames": ["/^@babel//"]
    },
    {
      "description": "Major updates need review",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "minimumReleaseAge": "7 days"
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/dist/**"]
}
